# =====================================================================
# Frontend (apps/web) — public + server vars
# =====================================================================

# SoSoValue API — docs: https://sosovalue-1.gitbook.io/sosovalue-api-doc
SOSOVALUE_API_KEY=
# Optional override (defaults to https://openapi.sosovalue.com)
# SOSOVALUE_API_BASE=

# SoDEX API — docs: https://sodex.com/documentation/api/api
# Mainnet key requires Silver SoPoints rank or buildathon whitelist.
# Testnet (testnet.sodex.com) does not require an API key.
SODEX_API_KEY=
# SODEX_API_BASE=
# Public browser client. Defaults to testnet unless set to "mainnet".
NEXT_PUBLIC_SODEX_NETWORK=testnet
# Optional override, e.g. https://testnet-gw.sodex.dev/api/v1/spot
# NEXT_PUBLIC_SODEX_API_BASE=
# EIP-712 chain id used for signed SoDEX writes. Required for testnet unless
# NEXT_PUBLIC_VALUECHAIN_TESTNET_ID is set; mainnet defaults to ValueChain.
# NEXT_PUBLIC_SODEX_CHAIN_ID=

# WalletConnect Cloud — https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ValueChain (SoDEX L1, EVM-compatible). Public infra values below were
# verified live via eth_chainId; leave blank to omit a chain entry.
# Mainnet: chainId 286623 (0x45f9f).
NEXT_PUBLIC_VALUECHAIN_ID=286623
NEXT_PUBLIC_VALUECHAIN_RPC=https://rpc.valuechain.xyz
NEXT_PUBLIC_VALUECHAIN_EXPLORER=https://main-scan.valuechain.xyz

# Testnet: chainId 138565 (0x21d45). Faucet (10,000 USDC + 100 $SOSO gas):
# https://testnet.sodex.com/faucet
NEXT_PUBLIC_VALUECHAIN_TESTNET_ID=138565
NEXT_PUBLIC_VALUECHAIN_TESTNET_RPC=https://testnet-rpc.valuechain.xyz
NEXT_PUBLIC_VALUECHAIN_TESTNET_EXPLORER=https://test-scan.valuechain.xyz

# Backend URL the web client calls server-side (e.g. http://localhost:8000)
VEGA_BACKEND_URL=http://localhost:8000

# Demo mode — when "1" (default), the browser fetch interceptor in
# lib/disable-missing-backend.ts returns shape-aware stubs for any
# localhost:8000 call so the static build runs with no backend. Set to
# "0" in `.env.local` while wiring real upstreams so failures surface.
NEXT_PUBLIC_DEMO_MODE=1

# =====================================================================
# Backend (services/vega-backend) — keep secrets here, not in NEXT_PUBLIC
# =====================================================================

# Supabase — https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres direct URL for Alembic migrations (Supabase: Settings → Database → Connection string → URI)
DATABASE_URL=

# AI provider keys for the Copilot. Choose at least one.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
